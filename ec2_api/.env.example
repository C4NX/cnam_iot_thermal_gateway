# Environment Configuration for EC2 API

# API Configuration
API_HOST=0.0.0.0
API_PORT=5001

# Alert threshold (temperature difference in degrees to trigger alert)
THRESHOLD_DIFFERENCE=5.0

# AWS Configuration
AWS_REGION=us-east-1
DYNAMODB_TABLE_NAME=iot-thermal-readings
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# (Or use IAM role on EC2 instance - no keys needed)
